{
	"name": "purch-api",
	"scripts": {
		"prepare": "husky",
		"dev": "bun run --hot src/index.ts",
		"frontend:dev": "npm --prefix apps/solana-frontend run dev",
		"frontend:build": "npm --prefix apps/solana-frontend run build",
		"frontend:preview": "npm --prefix apps/solana-frontend run preview",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"db:generate": "bunx drizzle-kit generate",
		"db:migrate": "bunx drizzle-kit push",
		"db:studio": "bunx drizzle-kit studio",
		"test:client": "bun run scripts/test-client.ts"
	},
	"dependencies": {
		"@coinbase/x402": "^2.0.0",
		"@scure/base": "^2.0.0",
		"@solana/web3.js": "^1.98.4",
		"@t3-oss/env-core": "^0.13.8",
		"@types/bcrypt": "^6.0.0",
		"@x402/core": "^2.1.0",
		"@x402/fetch": "^2.1.0",
		"@x402/hono": "^2.1.0",
		"@x402/svm": "^2.1.0",
		"bcrypt": "^6.0.0",
		"bs58": "^6.0.0",
		"drizzle-orm": "^0.44.7",
		"hono": "^4.10.4",
		"postgres": "^3.4.7",
		"viem": "^2.38.6",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.2",
		"@solana/addresses": "^2.0.0",
		"@solana/keys": "^2.0.0",
		"@solana/signers": "^2.0.0",
		"@types/bun": "latest",
		"dotenv": "^17.2.3",
		"drizzle-kit": "^0.31.6",
		"husky": "^9.1.7",
		"tsx": "^4.20.6"
	}
}
